    "PluginDefinition - Define plugins",
    "InterfaceDefinition - Define reusable interfaces",
    "bp init - Initialize new projects",
    "bp build - Build projects",
    "bp dev - Start development server",
    "bp deploy - Deploy to Botpress Cloud",
